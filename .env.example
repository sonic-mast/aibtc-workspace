# ==============================================================================
# AIBTC agent workspace — environment variables
# ==============================================================================
# Copy this file to `.env` and fill in each value. `.env` is gitignored.
# Most of these are also needed in the Claude Code scheduled task environment
# (remote and local). Set them in Claude Code's env config, not just here.
# ==============================================================================

# --- Agent wallet ---------------------------------------------------------------

# BIP-39 mnemonic for your agent's Bitcoin + Stacks wallet.
# Generate a fresh 12 or 24-word phrase and store it securely. This is the
# seed the heartbeat worker + remote triggers use to derive keys and sign.
# Never commit, never paste into chat, never push to any remote env you
# don't own.
AIBTC_MNEMONIC="twelve or twenty four words goes here separated by single spaces"

# Password you used when calling wallet_create / wallet_import via the aibtc MCP.
# Unlocks the locally-encrypted wallet for signing operations.
AIBTC_WALLET_PASSWORD="a strong password you set when the wallet was created"

# Stacks network — use "mainnet" for live activity. "testnet" is for dry runs;
# most aibtc.com / aibtc.news endpoints only accept mainnet addresses.
NETWORK=mainnet

# --- State API (your own Cloudflare Worker) -------------------------------------

# Bearer token for reads/writes to YOUR state worker. Generate once:
#   openssl rand -hex 32
# Then set it as a secret on your deployed state worker:
#   cd workers/state && wrangler secret put STATE_API_TOKEN
# And give this same value to anything that calls the state API — remote
# triggers, local triggers, the heartbeat worker (via `wrangler secret put`).
STATE_API_TOKEN=""

# --- Cloudflare (for deploying workers) -----------------------------------------

# API token with Workers + KV write permission. Create at
# https://dash.cloudflare.com/profile/api-tokens — "Edit Cloudflare Workers"
# template works out of the box. Only needed for `wrangler deploy`; not read
# by the workers themselves at runtime.
CLOUDFLARE_API_TOKEN=""

# --- GitHub (for code work + autonomous engagement) -----------------------------

# Classic personal access token from the account your agent will commit as.
# Scopes needed: repo, workflow, read:org.
# Used by the combined prompt to open PRs, respond to @-mentions, and
# monitor release feeds.
GITHUB_TOKEN=""

# --- Research / news sources (optional but recommended) ------------------------

# twitterapi.io key — used by the combined prompt to pull KOL tweets on the
# Bitcoin Macro beat. Free tier is sufficient for hourly runs.
# https://twitterapi.io
TWITTER_API_KEY=""

# Brave Search API key for web research. ~$5/month budget is plenty for
# daily usage. Used as a fallback source when Vibewatch/Twitter don't
# surface what you need. https://api.search.brave.com
BRAVE_API_KEY=""

# --- Daily digest (Telegram notifications) --------------------------------------

# Bot token from @BotFather on Telegram. The daily digest prompt uses this
# to send the operator a morning summary of the past 24h of runs.
# Message @BotFather, /newbot, save the token it gives you.
TELEGRAM_BOT_TOKEN=""

# Your personal Telegram chat ID (not the bot's). Get it by messaging your
# bot once, then visiting
#   https://api.telegram.org/bot{TOKEN}/getUpdates
# and copying the `chat.id` from the response.
TELEGRAM_CHAT_ID=""

# --- Pre-push code review gate -------------------------------------------------

# Google AI Studio API key for the pre-push review gate in phase 5 of the
# combined prompt. Uses `gemini-2.5-flash` within its free tier (15 RPM /
# 1500 RPD) — covers normal code-work volume with room to spare.
# Mint at https://aistudio.google.com/apikey (no billing required, key is
# tied to your personal Google account). Set it on BOTH the local .env AND
# the remote Claude Code trigger — the gate is designed to run in both
# environments so code work keeps shipping when your machine is off.
# If unset, the gate logs `localReviewResult="no-key"` and skips (push still
# proceeds) — it's a reviewer, not a required signer.
GEMINI_API_KEY=""
