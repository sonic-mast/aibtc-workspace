{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "x402-multi-token",
  "main": "src/index.ts",
  "compatibility_date": "2026-01-14",
  "compatibility_flags": ["nodejs_compat_v2"],
  "workers_dev": true,
  "vars": {
    "NETWORK": "mainnet",
    "RELAY_URL": "https://x402-relay.aibtc.com"
  },
  "env": {
    "staging": {
      "name": "x402-multi-token-staging",
      "workers_dev": true,
      "vars": {
        "NETWORK": "testnet",
        "RELAY_URL": "https://x402-relay.aibtc.dev"
      }
    },
    "production": {
      "name": "x402-multi-token",
      "workers_dev": false,
      "vars": {
        "NETWORK": "mainnet",
        "RELAY_URL": "https://x402-relay.aibtc.com"
      }
    }
  }
}
