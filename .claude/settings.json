{
  "disableRemoteControl": true,
  "permissions": {
    "allow": [
      "mcp__aibtc",
      "Bash(curl *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(cat *)",
      "Bash(node *)",
      "Bash(python3 *)",
      "Bash(date *)",
      "Bash(jq *)",
      "Bash(env)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(npx *)",
      "Bash(bash scripts/publish-gist.sh:*)",
      "Bash(scripts/publish-gist.sh:*)",
      "Bash(./scripts/publish-gist.sh:*)",
      "Bash(bash scripts/memory-commit.sh:*)",
      "Bash(scripts/memory-commit.sh:*)",
      "Bash(./scripts/memory-commit.sh:*)",
      "Bash(mkdir -p /tmp*)",
      "Bash(npm view *)",
      "Bash(npm ls *)",
      "Bash(git pull --ff-only*)",
      "Bash(source .env)",
      "Bash(wait)",
      "mcp__scheduled-tasks__list_scheduled_tasks",
      "Write(/tmp/*)",
      "Read(/tmp/*)",
      "Write(automation-state/*)",
      "Edit(automation-state/*)",
      "Write(reference/*)",
      "Edit(reference/*)",
      "WebSearch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-$PWD}/.claude/hooks/pattern_check.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-$PWD}/.claude/hooks/diff_review.py\""
          }
        ]
      }
    ]
  }
}
